# includeIf Git 2.36
#
# 已知坑: hasconfig:remote.*.url: 只有 C 版 git (>=2.36) 支持, libgit2 不支持。
# 因此 gitui / 任何基于 libgit2 的工具在这些仓库里读不到 user.name / user.email,
# 会报: git error:config value 'user.name' was not found; class=Config (7); code=NotFound (-3)
# 而命令行 git config --get user.name 能拿到, 是因为走的是 C 版 git, 容易误以为已配好。
# 复现: gitui -w $HOME -d $HOME/.git (即 `git diffhome` alias) 提交时报错。
# 修复办法 (按需选, 当前未改):
#   1) 在本文件顶层直接配 user.name / user.email (简单但会丢失 personal/work 身份切换);
#   2) 改成 libgit2 也认的 [includeIf "gitdir:..."], 按仓库目录路径区分身份。
[includeIf "hasconfig:remote.*.url:https://**github.com/**"]
    path = .gitconfig.personal
[includeIf "hasconfig:remote.*.url:ssh://git@github.com/**"]
    path = .gitconfig.personal
[includeIf "hasconfig:remote.*.url:git@github.com:**/**"]
    path = .gitconfig.personal

[includeIf "hasconfig:remote.*.url:https://code.byted.org/**"]
    path = .gitconfig.work
[includeIf "hasconfig:remote.*.url:ssh://git@code.byted.org/**"]
    path = .gitconfig.personal
[includeIf "hasconfig:remote.*.url:git@code.byted.org:**/**"]
    path = .gitconfig.work

[core]
	editor = ~/.config/scripts/git-editor.sh
	# editor = code --wait
	autocrlf = input
	eol = lf
[alias]
	diffhome = !gitui -w $HOME -d $HOME/.git
	dlog = !git log --all --oneline --stat --graph --decorate
	st = !git status
	co = !git checkout
	pr = !git pull
	b = !git branch
[pull]
	rebase = false
[safe]
	directory = *
[push]
	default = current
[init]
	defaultBranch = master
# [credential]
# 	helper = store
[url "git@github.com:"]
        insteadOf = https://github.com/
[url "gitr"]
    insteadOf = git://git.byted.org/
[credential "https://code.byted.org"]
    username = wuweichao@bytedance.com
[url "ssh://wuweichao@git.byted.org:29418"]
    insteadOf = https://git.byted.org
[url "git@code.byted.org:"]
    insteadOf = https://code.byted.org/